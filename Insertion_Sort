li = [14,9,15,12,6,8,13]

for i in range(1,len(li)):
    j=i
    while j>0:
        if li[j]<li[j-1]:
            li[j],li[j-1]=li[j-1],li[j]
            j-=1
        else:
            break
    print(i,end=" ")
    print(li)
print(li)

Logic 2:
arr = [29,10,14,37,13]
# arr = [10,13,14,29,37]

n = len(arr)

for i in range(n):
    key = arr[i]
    j=i-1
    while j>=0 and arr[j]>key:
        arr[j+1] = arr[j]
        j-=1
    arr[j+1]=key
    print('Step:{}-->{}'.format(i+1,arr))
print(arr)
