        // Count, avg, min, max salary per dept
        record SalaryStats(long count, double avg, double min, double max) {}
        
        Map<String, SalaryStats> salSummaryPerDept = 
            emps.stream()
                .collect(Collectors.groupingBy(Emp::getDept,
