class Emp {
  int id;
  String name;
  String dept;     // can be null in some questions
  String role;
  double salary;
  List<String> skills;

  Emp(int id, String name, String dept, String role, double salary, List<String> skills) {
    this.id = id; this.name = name; this.dept = dept; this.role = role; this.salary = salary; this.skills = skills;
  }
  int getId(){ return id; }
  String getName(){ return name; }
  String getDept(){ return dept; }
  String getRole(){ return role; }
  double getSalary(){ return salary; }
  List<String> getSkills(){ return skills; }
}

class Transaction {
  String userId;
  LocalDateTime ts;
  double amount;
  String status; // SUCCESS/FAILED/etc
  Transaction(String userId, LocalDateTime ts, double amount, String status){
    this.userId=userId; this.ts=ts; this.amount=amount; this.status=status;
  }
  String getUserId(){ return userId; }
  LocalDateTime getTs(){ return ts; }
  double getAmount(){ return amount; }
  String getStatus(){ return status; }
}

class LineItem {
  String sku;
  int qty;
  double price;
  LineItem(String sku, int qty, double price){ this.sku=sku; this.qty=qty; this.price=price; }
  int getQty(){ return qty; }
  double getPrice(){ return price; }
}

class Order {
  String orderId;
  List<LineItem> items;
  Order(String orderId, List<LineItem> items){ this.orderId=orderId; this.items=items; }
  List<LineItem> getItems(){ return items; }
}

class Event {
  String id;
  LocalDateTime ts;
  Event(String id, LocalDateTime ts){ this.id=id; this.ts=ts; }
  LocalDateTime getTs(){ return ts; }
  public String toString(){ return id + "@" + ts; }
}

class Main {
    
    public static void main(String[] args) {
