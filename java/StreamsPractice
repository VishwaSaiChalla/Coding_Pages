import java.util.*;
import java.util.stream.*;

class Main {
    public static void main(String[] args) {
        
        // Find the sum of all integers in a list using streams.
        List<Integer> nums = Arrays.asList(54,67,23,48,50);
        List<String> fruits = Arrays.asList("apple","banana","grapes","apple","kiwi","berries");
        
        int numsSum = nums.stream()
                      .mapToInt(Integer::intValue)//map all Integer Object values to int values
                      .sum();// terminal opertion adds all int values.
        System.out.println(numsSum);
        
        
        // Find the maximum and minimum number in a list.
        Optional<Integer> maxNum = nums.stream().max((val1,val2)->{
            return val1.compareTo(val2);
        });
        
        System.out.println(maxNum.get());
        
        Optional<Integer> minNum = nums.stream().min((val1,val2)->{
            return val1.compareTo(val2);
        });
        System.out.println(minNum.get());
        
        // AI Answers.
        Optional<Integer> max = nums.stream()
                              .max(Integer::compareTo);
        // Integer::compareTo compares to int values

        Optional<Integer> min = nums.stream()
                              .min(Integer::compareTo);

        System.out.println("Max: " + max.get());
        System.out.println("Min: " + min.get());
        
        // Filter all even numbers from a list.
        List<Integer> evenNumbers = nums.stream().filter(num->num%2==0).collect(Collectors.toList());
        System.out.println(evenNumbers);
        
        Convert a list of strings to uppercase.
        List<String> uppercaseStr = fruits.stream().map(str->str.toUpperCase()).collect(Collectors.toList());
        
        List<String> uppercaseStr = fruits.stream().map(String::toUpperCase).collect(Collectors.toList());
        System.out.println(uppercaseStr);
        
        // Count strings starting with "A".
        long cnt = fruits.stream().filter(str->str.startsWith("a")).count();
        
        System.out.println(cnt);
        
        // Remove duplicate elements.
        List<String> uniqueFruits = fruits.stream().distinct().collect(Collectors.toList());
        System.out.println(uniqueFruits);
        
        // Sort ascending & descending.
        List<Integer> sortedNums = nums.stream().sorted().collect(Collectors.toList());
        List<Integer> sortedNums = nums.stream().sorted(Comparator.reverseOrder()).collect(Collectors.toList());
        System.out.println(sortedNums);
        
        List<String> sortedFruits = fruits.stream().sorted(Comparator.reverseOrder()).collect(Collectors.toList());
        System.out.println(sortedFruits);
        
        // Find first element
        Optional<Integer> firstEle = nums.stream().findFirst();
        System.out.println(firstEle.get());
        
        Optional<String> firstStrEle = fruits.stream().findFirst();
        System.out.println(firstStrEle.get());
        
        // Check if all numbers > 10
        boolean chkNums = nums.stream().allMatch(num->num>10);
        System.out.println(chkNums);
        
        // Check if any string contains "java" equals or contains
        boolean chkStr = fruits.stream().anyMatch(str->str.equals("apple"));
        System.out.println(chkStr);
    }
}
